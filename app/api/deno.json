{
  "deploy": {
    "org": "metapage",
    "app": "container"
  },
  "name": "@metapages/compute-queues-api",
  "exports": {},
  "tasks": {
    "start": "deno run -A --config deno.json src/server.ts"
  },
  "fmt": {
